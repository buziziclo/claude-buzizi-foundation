# Apify — Lead scraping via Google Maps
# Get your token at: apify.com → Settings → Integrations
APIFY_TOKEN=your_apify_token_here

# Vercel — Site deployment (optional, needed for remote/SSH setups)
# Get your token at: vercel.com/account/tokens
# If not set, you must run `vercel login` instead
VERCEL_TOKEN=

# Mission Control — Spend page daily budget thresholds (optional).
# Surfaced on /spend as: Today tile subtitle + dashed line on the daily-burn chart.
# Days that exceed the soft budget are marked red on the chart.
# Both vars are read by the backend (mission-control/overrides/backend/app/api/mc.py).
# These belong in /etc/openclaw-mission-control/.env (same place as OPENROUTER_API_KEY).
MC_OPENROUTER_DAILY_BUDGET_USD=
MC_OPENROUTER_DAILY_BUDGET_HARD_USD=
